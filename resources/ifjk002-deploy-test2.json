        "Code": "from awsglue.dynamicframe import DynamicFrame\nimport boto3\nfrom botocore.exceptions import ClientError\nfrom awsglue.utils import getResolvedOptions\nimport sys\nimport os\n\nlogger = glueContext.get_logger()\ninput_dyf = list(dfc.values())[0] if dfc else None\nlogger.info(\"CSVファイル存在チェックを開始しました\")\n# 入力パスを取得\nargs = getResolvedOptions(sys.argv, ['input_path'])\ns3_path = args['input_path']\nlogger.info(f\"s3_path: {s3_path}\")\n\n# S3パスを解析\npath_parts = s3_path.replace('s3://', '').split('/', 1)\nbucket, key = path_parts[0], path_parts[1]\n\n# ファイルをチェック\ns3_client = boto3.client('s3')\ntry:\n    s3_client.head_object(Bucket=bucket, Key=key)\n    logger.info(f\"ファイルが存在します: {s3_path}\")\n    \n    # ファイルが存在する場合、元のデータを返す\n    return DynamicFrameCollection({\"output\": input_dyf}, glueContext) if input_dyf else None\n    \nexcept ClientError as e:\n    if e.response['Error']['Code'] == '404':\n        logger.error(f\"ファイルが存在しません: {s3_path}\")\n        raise e\n    else:\n        logger.error(f\"ファイルチェックエラー: {str(e)}\")\n        raise e",
